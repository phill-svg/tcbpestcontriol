{
  "name": "tcbpestreal",
  "compatibility_date": "2026-07-09",
  "main": "src/index.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true,
    "html_handling": "none"
  },
  "durable_objects": {
    "bindings": [
      { "name": "CHAT_HUB", "class_name": "ChatHub" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChatHub"] }
  ]
}
